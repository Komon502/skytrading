# ============================================================
# SkyTrading - Environment Variables
# Copy to .env.local (never commit .env.local to git)
# ============================================================

# Supabase (get from https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # server-side only

# Finnhub (get from https://finnhub.io - free tier: 60 req/min)
NEXT_PUBLIC_FINNHUB_KEY=your-finnhub-api-key

# SlipOk (get from https://slipok.com - Thai bank slip verification)
SLIPOK_BRANCH_ID=your-branch-id
SLIPOK_API_KEY=your-slipok-api-key

# ============================================================
# Vercel Deployment Notes:
# 1. Push code to GitHub
# 2. Connect GitHub repo to Vercel
# 3. Add all env vars above in Vercel Dashboard > Settings > Environment Variables
# 4. Deploy!
#
# Supabase Setup:
# 1. Create new project at supabase.com
# 2. Go to SQL Editor, paste content of supabase-schema.sql, run it
# 3. Go to Storage, create bucket named "slips" (private)
# 4. Copy URL and keys to .env.local
#
# SlipOk Setup:
# 1. Register at slipok.com
# 2. Create a Branch and get Branch ID
# 3. Generate API Key in dashboard
# ============================================================
